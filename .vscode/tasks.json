{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "bun run debug",
      "type": "shell",
      "command": "bun run debug",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "bun",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Bun Inspector.*",
          "endsPattern": ".*Listening:.*"
        }
      },
      "runOptions": {
        "runOn": "folderOpen",
        "instanceLimit": 1
      }
    }
  ]
}
