  "version": "0.2.0",
  "configurations": [
    {
      "name": "⚡️ Attach to claude code",
      "type": "bun",
      "request": "attach",
      "url": "ws://localhost:6499/",
      "preLaunchTask": "bun run debug",
      "stopOnEntry": false,
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Attach to claude code",
      "type": "bun",
      "request": "attach",
      "url": "ws://localhost:6499/",
      "stopOnEntry": false,
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Attach to dist",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "internalConsoleOptions": "neverOpen"
    },
    {
      "type": "bun",
      "internalConsoleOptions": "neverOpen",
      "request": "launch",
      "name": "Run File",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "noDebug": true,
      "watchMode": false
    }
  ]
}
